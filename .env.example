# Copy this file to .env and fill in your actual values.
# .env is in .gitignore and will NEVER be committed to Git.

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your_flask_secret_key_here

# Ollama server URL (for local development)
OLLAMA_URL=http://localhost:11434

# Add any external API keys below (e.g., if you integrate cloud LLMs later):
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# GOOGLE_API_KEY=AIzaSy-xxxxxxxxxxxxxxxx
